PORT=5000

# https://resend.com/api-keys — add domain imototocleanings.co.uk in Resend first
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend (after DNS: DKIM resend._domainkey + SPF include:amazonses.com)
# Cloudflare @ SPF merge: v=spf1 include:privateemail.com include:amazonses.com ~all
EMAIL_FROM=Imototo Cleaning Services <info@imototocleanings.co.uk>

# Inbox where quote/contact emails are delivered
RECIPIENT_EMAIL=info@imototocleanings.co.uk

# Admin reply app (set a strong password — never commit real value)
ADMIN_PASSWORD=your-strong-password-here
# Optional: comma-separated origins for deployed admin (e.g. https://admin.imototocleanings.co.uk)
# ADMIN_ALLOWED_ORIGINS=
# ADMIN_SESSION_TTL_MS=28800000
